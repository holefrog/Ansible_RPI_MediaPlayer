[Unit]
Description=Bluetooth A2DP Auto-Pairing Service
Documentation=man:bluetoothctl(1) man:bt-agent(1)
After=network.target bluetooth.service pipewire.service user@{{ USER_ID }}.service
Requires=bluetooth.service
Wants=pipewire.service user@{{ USER_ID }}.service

[Service]
Type=simple
User=root
Environment="USER_RUNTIME_DIR={{ USER_RUNTIME_DIR }}"
# 在执行主脚本前，先由 Systemd 阻塞等待 PipeWire 就绪
ExecStartPre=/bin/bash -c "while ! sudo -u {{ USER_NAME }} XDG_RUNTIME_DIR={{ USER_RUNTIME_DIR }} pactl info >/dev/null 2>&1; do sleep 2; done"
ExecStart={{ SYSTEM_BIN_DIR }}/bluetooth-a2dp-autopair.sh
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# 安全设置
NoNewPrivileges=false
PrivateTmp=false

[Install]
WantedBy=multi-user.target
